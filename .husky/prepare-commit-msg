COMMIT_MSG_FILE=$1
COMMIT_SOURCE=$2

# merge / squash / rebase / cherry-pick 은 건너뜀
case "$COMMIT_SOURCE" in
  merge|squash|template|commit) exit 0 ;;
esac

# initial commit 시 git rev-parse 가 비0 으로 종료되어 set -e 환경에서 hook 이
# 깨지는 것을 막기 위해 fallback 으로 HEAD 를 사용.
BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "HEAD")
case "$BRANCH" in
  main|master|develop|HEAD) exit 0 ;;
esac

# 브랜치명에서 [PROJECT]-[NUMBER] 패턴 추출 (WW-123 등)
TICKET=$(printf '%s' "$BRANCH" | grep -oE '[A-Z]+-[0-9]+' | head -n 1)

if [ -z "$TICKET" ]; then
  exit 0
fi

# 이미 메시지에 Clawket-Ref 가 있으면 skip
if grep -qE '^Clawket-Ref:' "$COMMIT_MSG_FILE"; then
  exit 0
fi

# 메시지 끝에 Clawket-Ref 라인 추가
{
  cat "$COMMIT_MSG_FILE"
  printf '\n\nClawket-Ref: %s\n' "$TICKET"
} > "$COMMIT_MSG_FILE.tmp" && mv "$COMMIT_MSG_FILE.tmp" "$COMMIT_MSG_FILE"
