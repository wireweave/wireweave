{
  "name": "@wireweave/agent-prompts",
  "version": "0.1.1",
  "description": "Canonical grammar prompts for LLM agents generating Wireweave DSL (multi-page aware)",
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "knip",
    "publint": "publint",
    "packlint": "packlint check",
    "clean": "rm -rf dist",
    "release": "release-it",
    "release:beta": "release-it --preRelease=beta"
  },
  "lint-staged": {
    "*.{ts,js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint/js": "^10.0.1",
    "@packlint/cli": "^0.0.2",
    "@release-it/conventional-changelog": "^10.0.4",
    "@types/node": "^22.0.0",
    "eslint": "^10.4.0",
    "husky": "^9.1.7",
    "knip": "^6.14.2",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "publint": "^0.3.21",
    "release-it": "^19.2.3",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.60.0",
    "vitest": "^3.1.1"
  },
  "keywords": [
    "wireframe",
    "dsl",
    "llm",
    "prompt",
    "agent",
    "wireweave"
  ],
  "author": "Seungwoo Lee",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wireweave/agent-prompts.git"
  },
  "bugs": {
    "url": "https://github.com/wireweave/agent-prompts/issues"
  },
  "homepage": "https://github.com/wireweave/agent-prompts#readme"
}
