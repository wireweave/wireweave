{
  "name": "@wireweave/core",
  "version": "3.0.1-beta.0",
  "description": "Core parser and renderer for wireweave",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./parser": {
      "types": "./dist/parser.d.ts",
      "import": "./dist/parser.js",
      "require": "./dist/parser.cjs"
    },
    "./renderer": {
      "types": "./dist/renderer.d.ts",
      "import": "./dist/renderer.js",
      "require": "./dist/renderer.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build:grammar": "peggy --format es -o src/parser/generated-parser.js src/grammar/wireframe.peggy",
    "build:ts": "tsup",
    "build": "pnpm build:grammar && pnpm build:ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "knip",
    "prepare": "husky",
    "release": "release-it"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint/js": "^10.0.1",
    "@release-it/conventional-changelog": "^10.0.4",
    "@storybook/html": "^10.2.18",
    "@storybook/html-vite": "^10.2.18",
    "@types/node": "^25.0.8",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^10.3.0",
    "husky": "^9.1.7",
    "knip": "^6.13.1",
    "lint-staged": "^17.0.4",
    "lucide": "^0.562.0",
    "peggy": "^5.0.0",
    "prettier": "^3.8.3",
    "release-it": "^19.2.3",
    "storybook": "^10.2.18",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.59.3",
    "vitest": "^3.1.1"
  },
  "keywords": [
    "wireframe",
    "dsl",
    "parser",
    "ui",
    "prototyping",
    "design"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wireweave/core.git"
  }
}
